<Window x:Class="IT2A_databaze.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Evidence aut" Height="450" Width="800">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <DataGrid x:Name="dgAuta"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Značka" Binding="{Binding Znacka}" Width="*"/>
                <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="*"/>
                <DataGridTextColumn Header="Rok výroby" Binding="{Binding RokVyroby}" Width="100"/>
                <DataGridTextColumn Header="Ks skladem" Binding="{Binding PocetKusu}" Width="100"/>
            </DataGrid.Columns>

        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Přidat" Width="150" Margin="10" Click="Pridat_Click"/>
            <Button Content="Upravit" Width="150" Margin="10"/>
            <Button Content="Odebrat" Width="150" Margin="10" Click="Smazat_Click"/>
        </StackPanel>

    </Grid>
</Window>